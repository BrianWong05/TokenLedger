{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenLedger",
  "version": "0.1.0",
  "identifier": "com.brianwong.tokenledger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "TokenLedger",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false,
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      },
      {
        "label": "traypanel",
        "url": "index.html?panel=1",
        "title": "TokenLedger Panel",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "width": 300,
        "height": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BrianWong05/TokenLedger/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0MzA4ODA2NDYxMjBEQkMKUldTOERSSkdCb2d3TkZWUDIya1A5ZlVyazZpVXBUd0IwZGpYc2ZmSkNSNFA4dllXQ0E2dTlhK3EK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  }
}

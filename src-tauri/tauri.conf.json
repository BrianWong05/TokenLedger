{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenLedger",
  "version": "0.1.0",
  "identifier": "com.brianwong.tokenledger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TokenLedger",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false,
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BrianWong05/TokenLedger/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IFRva2VuTGVkZ2VyIHVwZGF0ZXIgcHVia2V5IC0tIFBMQUNFSE9MREVSLCByZXBsYWNlIGJlZm9yZSByZWxlYXNlCg=="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
